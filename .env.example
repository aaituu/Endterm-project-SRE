NODE_ENV=production

# Published local ports.
FRONTEND_PORT=8088
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
SCHOOL_SERVICE_PORT=3003
ACADEMIC_SERVICE_PORT=3004
ASSIGNMENT_SERVICE_PORT=3005
CONTENT_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
POSTGRES_PORT=55432
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NODE_EXPORTER_PORT=9100

# Database. In Docker Compose DB_HOST must stay "postgres".
DB_HOST=postgres
DB_PORT=5432
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=change-this-database-password
DB_TENANT_PREFIX=school_tenant

# Auth. JWT_SECRET must be long and private in production.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Public frontend URL used by backend CORS and links.
FRONTEND_URL=http://localhost:8088

# API gateway.
UPSTREAM_TIMEOUT_MS=30000

# Upload/import limits in bytes.
MAX_FILE_SIZE=10485760
MAX_IMPORT_FILE_SIZE=20971520

# Telegram bot integration. Keep disabled unless you set real credentials.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_POLLING_ENABLED=false

# Grafana local login. Change this for any shared server.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
