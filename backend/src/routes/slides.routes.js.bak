const express = require('express');
const router = express.Router();
const { query } = require('../config/db');
const { authenticate } = require('../middleware/auth');
const { requireAdmin } = require('../middleware/rbac');
const { asyncHandler } = require('../utils/helpers');
const upload = require('../middleware/upload');

// GET /api/slides  (public)
router.get('/', asyncHandler(async (req, res) => {
  const result = await query('SELECT * FROM slides WHERE is_active = TRUE ORDER BY sort_order ASC');
  res.json({ success: true, data: result.rows });
}));

// GET /api/slides/all  (admin - includes inactive)
router.get('/all', authenticate, requireAdmin, asyncHandler(async (req, res) => {
  const result = await query('SELECT * FROM slides ORDER BY sort_order ASC');
  res.json({ success: true, data: result.rows });
}));

// POST /api/slides
router.post('/', authenticate, requireAdmin, upload.single('image'), asyncHandler(async (req, res) => {
  const { title_kz, quote, sort_order } = req.body;
  const image_url = req.file ? `resources/${req.file.filename}` : (req.body.image_url || null);
  const result = await query(
    'INSERT INTO slides (title_kz, quote, image_url, sort_order) VALUES ($1,$2,$3,$4) RETURNING *',
    [title_kz, quote, image_url, sort_order || 0]
  );
  res.status(201).json({ success: true, data: result.rows[0] });
}));

// PUT /api/slides/:id
router.put('/:id', authenticate, requireAdmin, upload.single('image'), asyncHandler(async (req, res) => {
  const { title_kz, quote, sort_order, is_active } = req.body;
  const image_url = req.file ? `resources/${req.file.filename}` : (req.body.image_url || null);
  const result = await query(
    `UPDATE slides SET
      title_kz = COALESCE($1, title_kz),
      quote = COALESCE($2, quote),
      image_url = COALESCE($3, image_url),
      sort_order = COALESCE($4, sort_order),
      is_active = COALESCE($5, is_active)
     WHERE id = $6 RETURNING *`,
    [title_kz, quote, image_url, sort_order, is_active !== undefined ? is_active : null, req.params.id]
  );
  if (!result.rows[0]) return res.status(404).json({ success: false, message: 'Слайд табылмады' });
  res.json({ success: true, data: result.rows[0] });
}));

// DELETE /api/slides/:id
router.delete('/:id', authenticate, requireAdmin, asyncHandler(async (req, res) => {
  const result = await query('DELETE FROM slides WHERE id = $1 RETURNING id', [req.params.id]);
  if (!result.rows[0]) return res.status(404).json({ success: false, message: 'Слайд табылмады' });
  res.json({ success: true, message: 'Слайд жойылды' });
}));

module.exports = router;
