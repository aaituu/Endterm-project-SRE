{
  "name": "school-backend",
  "version": "1.0.0",
  "description": "School management system backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node scripts/run_all_migrations.js",
    "db:setup": "node scripts/run_all_migrations.js --with-schema",
    "db:seed": "node seed.js",
    "db:provision-schools": "node scripts/provision_school_databases.js",
    "db:init": "npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
